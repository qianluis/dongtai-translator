.container { padding: 16px; background: #f0f4f8; min-height: 100vh; }
.header { text-align: center; padding: 12px 0; }
.logo { font-size: 48px; }
.title { font-size: 22px; font-weight: bold; color: #1a73e8; margin: 6px 0; }
.subtitle { font-size: 12px; color: #888; }
.card { background: #fff; border-radius: 12px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.input-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.input-label { font-size: 14px; color: #333; font-weight: 600; }
.input-area { width: 100%; min-height: 80px; padding: 12px; border: 1px solid #e0e0e0; border-radius: 8px; font-size: 16px; line-height: 1.6; }
.input-actions { display: flex; gap: 8px; margin-top: 10px; }
.action-btn { padding: 8px 16px; border-radius: 8px; background: #f5f5f5; font-size: 14px; }
.action-btn.primary { background: #1a73e8; color: #fff; }
.action-btn.speak-btn { background: #e8f5e9; color: #2e7d32; }
.action-btn.speak-btn-large { 
  background: linear-gradient(135deg, #00d2d3, #01a3a4); 
  color: #fff; 
  font-size: 16px; 
  padding: 12px 24px; 
  font-weight: 600;
  flex: 1;
  text-align: center;
}
.action-btn.speak-btn-large.speaking { 
  background: linear-gradient(135deg, #ff6b6b, #ee5a24); 
}
.result-card { border-left: 4px solid #1a73e8; }
.result-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px; }
.result-label { font-size: 14px; color: #1a73e8; font-weight: 600; }
.confidence { font-size: 12px; color: #888; }
.result-text { font-size: 18px; line-height: 1.8; color: #333; padding: 8px 0; }
.result-actions { display: flex; gap: 8px; margin-top: 10px; }
.asr-note { margin-top: 8px; font-size: 12px; color: #2e7d32; background: #e8f5e9; padding: 6px 12px; border-radius: 6px; }
.section-title { font-size: 14px; color: #333; font-weight: 600; margin-bottom: 8px; }
.quick-grid { display: flex; flex-wrap: wrap; gap: 6px; }
.quick-item { background: #f5f5f5; padding: 6px 14px; border-radius: 16px; font-size: 13px; }
