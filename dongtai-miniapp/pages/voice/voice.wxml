<view class="container">
  <view class="header">
    <view class="title">🎤 语音翻译</view>
    <view class="subtitle">说普通话或东台话，自动识别+翻译+朗读</view>
  </view>

  <!-- 大按钮 -->
  <view class="mic-area">
    <view class="mic-btn {{isListening ? 'recording' : ''}}" bindtap="toggleRecord">
      <text class="mic-icon">{{isListening ? '⏹' : '🎤'}}</text>
    </view>
    <text class="mic-hint">{{isListening ? '点击停止' : '点击开始说话'}}</text>
  </view>

  <!-- 识别结果 -->
  <view class="result-card card" wx:if="{{recognized}}">
    <view class="result-section">
      <text class="section-label">🔍 语音识别</text>
      <text class="section-text">{{recognized}}</text>
    </view>
    <view class="result-section" wx:if="{{asrCorrected}}">
      <text class="section-label success">✅ ASR纠错</text>
      <text class="section-text">{{corrected}}</text>
    </view>
    <view class="result-section">
      <text class="section-label accent">📝 翻译结果</text>
      <text class="section-text highlight">{{translated}}</text>
    </view>
    <view class="speak-row">
      <view class="speak-btn {{isSpeaking ? 'speaking' : ''}}" bindtap="speakText">
        {{isSpeaking ? '🔊 朗读中...' : '🔊 朗读翻译结果'}}
      </view>
      <view class="copy-btn" bindtap="copyText">📋 复制</view>
    </view>
  </view>

  <!-- 历史 -->
  <view class="history-card card" wx:if="{{history.length > 0}}">
    <text class="section-title">📜 历史记录</text>
    <view class="history-item" wx:for="{{history}}" wx:key="index">
      <view class="history-from">{{item.from}}</view>
      <view class="history-arrow">→</view>
      <view class="history-to">{{item.to}}</view>
    </view>
  </view>
</view>
