.container { padding: 16px; background: #f0f4f8; min-height: 100vh; }
.header { text-align: center; padding: 20px 0; }
.title { font-size: 22px; font-weight: bold; color: #1a73e8; }
.subtitle { font-size: 12px; color: #888; margin-top: 4px; }
.mic-area { text-align: center; padding: 30px 0; }
.mic-btn { width: 100px; height: 100px; border-radius: 50%; background: linear-gradient(135deg, #48dbfb, #0abde3); display: inline-flex; align-items: center; justify-content: center; box-shadow: 0 4px 20px rgba(72,219,251,0.4); }
.mic-btn.recording { background: linear-gradient(135deg, #ff6b6b, #ee5a24); box-shadow: 0 4px 20px rgba(255,107,107,0.4); }
.mic-icon { font-size: 40px; }
.mic-hint { display: block; margin-top: 12px; color: #888; font-size: 14px; }
.card { background: #fff; border-radius: 12px; padding: 16px; margin-bottom: 12px; box-shadow: 0 2px 8px rgba(0,0,0,0.06); }
.result-section { margin-bottom: 12px; padding-bottom: 12px; border-bottom: 1px solid #f0f0f0; }
.result-section:last-of-type { border-bottom: none; }
.section-label { font-size: 13px; color: #666; display: block; margin-bottom: 4px; }
.section-label.success { color: #2e7d32; }
.section-label.accent { color: #1a73e8; }
.section-text { font-size: 16px; color: #333; line-height: 1.6; }
.highlight { font-size: 18px; font-weight: 600; color: #1a73e8; }
.speak-row { display: flex; gap: 8px; margin-top: 12px; }
.speak-btn { 
  flex: 1; 
  text-align: center; 
  padding: 14px; 
  border-radius: 10px; 
  background: linear-gradient(135deg, #00d2d3, #01a3a4); 
  color: #fff; 
  font-size: 16px; 
  font-weight: 600; 
}
.speak-btn.speaking { background: linear-gradient(135deg, #ff6b6b, #ee5a24); }
.copy-btn { padding: 14px 20px; border-radius: 10px; background: #f5f5f5; font-size: 14px; }
.section-title { font-size: 14px; color: #333; font-weight: 600; margin-bottom: 8px; }
.history-item { display: flex; align-items: center; gap: 8px; padding: 8px 0; border-bottom: 1px solid #f5f5f5; }
.history-from { color: #666; font-size: 13px; flex: 1; }
.history-arrow { color: #1a73e8; }
.history-to { color: #333; font-size: 13px; font-weight: 600; flex: 1; }
