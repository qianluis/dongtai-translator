.container { padding: 24rpx; min-height: 100vh; background: linear-gradient(180deg, #e8f0fe 0%, #f0f4f8 30%); }
.header { text-align: center; padding: 40rpx 0; }
.title { font-size: 40rpx; font-weight: 700; color: #1a73e8; }
.subtitle { font-size: 24rpx; color: #666; margin-top: 8rpx; }
.mic-area { display: flex; flex-direction: column; align-items: center; padding: 60rpx 0; }
.mic-btn { width: 200rpx; height: 200rpx; border-radius: 50%; background: linear-gradient(135deg, #1a73e8, #4285f4); display: flex; align-items: center; justify-content: center; box-shadow: 0 8rpx 32rpx rgba(26,115,232,0.3); transition: all 0.3s; }
.mic-btn.listening { background: linear-gradient(135deg, #ea4335, #f44336); box-shadow: 0 8rpx 32rpx rgba(234,67,53,0.4); transform: scale(1.1); }
.mic-icon { font-size: 72rpx; }
.mic-text { margin-top: 20rpx; font-size: 28rpx; color: #666; }
.wave { display: flex; justify-content: center; gap: 12rpx; margin: 30rpx 0; }
.wave-bar { width: 8rpx; height: 40rpx; background: #1a73e8; border-radius: 4rpx; animation: wave-anim 0.8s ease-in-out infinite alternate; }
@keyframes wave-anim { 0% { height: 20rpx; } 100% { height: 80rpx; } }
.card { background: #fff; border-radius: 24rpx; padding: 30rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.card-label { font-size: 24rpx; color: #1a73e8; font-weight: 600; margin-bottom: 12rpx; }
.card-text { font-size: 32rpx; line-height: 1.6; color: #333; }
.card-text.big { font-size: 40rpx; font-weight: 600; }
.result-card { border-left: 6rpx solid #34a853; }
.card-actions { display: flex; gap: 20rpx; margin-top: 16rpx; }
.action-btn { background: #f0f4f8; color: #555; padding: 12rpx 32rpx; border-radius: 30rpx; font-size: 24rpx; }
.asr-note { font-size: 22rpx; color: #34a853; background: #e6f4ea; padding: 8rpx 16rpx; border-radius: 12rpx; margin-top: 12rpx; }
.history { margin-top: 20rpx; }
.section-title { font-size: 28rpx; font-weight: 600; margin-bottom: 16rpx; }
.history-item { display: flex; align-items: center; padding: 16rpx 0; border-bottom: 1rpx solid #f0f0f0; }
.hist-from { flex: 1; font-size: 26rpx; color: #666; }
.hist-arrow { color: #1a73e8; margin: 0 16rpx; }
.hist-to { flex: 1; font-size: 26rpx; color: #333; font-weight: 500; }
