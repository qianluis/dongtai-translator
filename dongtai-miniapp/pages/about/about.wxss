.container { padding: 24rpx; background: #f0f4f8; min-height: 100vh; }
.header { text-align: center; padding: 50rpx 0 30rpx; }
.logo { font-size: 80rpx; }
.title { font-size: 40rpx; font-weight: 700; color: #1a73e8; margin-top: 10rpx; }
.version { font-size: 24rpx; color: #999; margin-top: 8rpx; }
.card { background: #fff; border-radius: 24rpx; padding: 30rpx; margin-bottom: 24rpx; box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06); }
.section-title { font-size: 28rpx; font-weight: 600; color: #333; margin-bottom: 20rpx; padding-left: 16rpx; border-left: 6rpx solid #1a73e8; }
.stat-row { display: flex; justify-content: space-between; padding: 12rpx 0; border-bottom: 1rpx solid #f5f5f5; }
.stat-label { color: #666; font-size: 26rpx; }
.stat-value { font-weight: 600; font-size: 26rpx; }
.stat-value.highlight { color: #1a73e8; }
.cat-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 16rpx; }
.cat-item { display: flex; align-items: center; padding: 16rpx; background: #f8f9fa; border-radius: 16rpx; }
.cat-icon { font-size: 32rpx; margin-right: 12rpx; }
.cat-name { font-size: 26rpx; color: #333; flex: 1; }
.cat-count { font-size: 22rpx; color: #999; }
.feature-list { }
.feature-item { padding: 12rpx 0; font-size: 26rpx; color: #555; }
.link { color: #1a73e8; font-size: 26rpx; padding: 12rpx 0; }
.footer { text-align: center; padding: 40rpx 0; color: #999; font-size: 22rpx; }
