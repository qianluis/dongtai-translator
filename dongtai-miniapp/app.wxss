page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  background-color: #f5f5f5;
  color: #333;
  font-size: 28rpx;
}
.container {
  padding: 30rpx;
}
.card {
  background: #fff;
  border-radius: 20rpx;
  padding: 30rpx;
  margin-bottom: 24rpx;
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.06);
}
.title {
  font-size: 36rpx;
  font-weight: 600;
  margin-bottom: 20rpx;
}
.blue-btn {
  background: linear-gradient(135deg, #1a73e8, #4285f4);
  color: #fff;
  border: none;
  border-radius: 50rpx;
  padding: 24rpx 48rpx;
  font-size: 30rpx;
  font-weight: 500;
}
.blue-btn::after { border: none; }
