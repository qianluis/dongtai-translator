<view class="container">
  <view class="card" style="text-align:center;padding:20rpx 16rpx">
    <view class="gradient-text" style="font-size:36rpx;font-weight:700">📚 方言词典</view>
    <view style="font-size:22rpx;color:rgba(255,255,255,.4);margin-top:8rpx">500+东台话核心词汇</view>
  </view>

  <!-- 搜索 -->
  <view class="search-box">
    <input class="search-input" placeholder="搜索方言词或普通话..." value="{{searchKey}}" bindinput="onSearch" />
  </view>

  <!-- 词典内容 -->
  <view wx:for="{{dictSections}}" wx:key="title" class="dict-section">
    <view class="dict-title">{{item.title}}</view>
    <view class="dict-items">
      <view wx:for="{{item.items}}" wx:for-item="word" wx:key="from" 
            class="dict-item" bindtap="useWord" data-from="{{word.from}}" data-to="{{word.to}}">
        <text class="dict-from">{{word.from}}</text>
        <text class="dict-arrow">→</text>
        <text class="dict-to">{{word.to}}</text>
      </view>
    </view>
  </view>
</view>
