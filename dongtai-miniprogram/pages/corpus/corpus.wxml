<view class="container">
  <view class="card" style="text-align:center;padding:20rpx 16rpx">
    <view class="gradient-text" style="font-size:36rpx;font-weight:700">📖 语料浏览</view>
    <view style="font-size:22rpx;color:rgba(255,255,255,.4);margin-top:8rpx">400K东台话语料库精选</view>
  </view>

  <!-- 搜索 -->
  <view class="search-box">
    <input class="search-input" placeholder="搜索语料..." value="{{searchKey}}" bindinput="onSearch" confirm-type="search" bindconfirm="doSearch" />
  </view>

  <!-- 分类筛选 -->
  <scroll-view scroll-x style="white-space:nowrap;margin-bottom:16rpx">
    <view class="filter-row" style="display:inline-flex">
      <view class="filter-pill {{curCat==='all'?'active':''}}" bindtap="filterCat" data-cat="all">全部</view>
      <view class="filter-pill {{curCat==='survival'?'active':''}}" bindtap="filterCat" data-cat="survival">生存刚需</view>
      <view class="filter-pill {{curCat==='social'?'active':''}}" bindtap="filterCat" data-cat="social">社交融入</view>
      <view class="filter-pill {{curCat==='medical'?'active':''}}" bindtap="filterCat" data-cat="medical">医疗健康</view>
      <view class="filter-pill {{curCat==='government'?'active':''}}" bindtap="filterCat" data-cat="government">政务办事</view>
      <view class="filter-pill {{curCat==='workplace'?'active':''}}" bindtap="filterCat" data-cat="workplace">职场沟通</view>
      <view class="filter-pill {{curCat==='culture'?'active':''}}" bindtap="filterCat" data-cat="culture">文化生活</view>
      <view class="filter-pill {{curCat==='dialect'?'active':''}}" bindtap="filterCat" data-cat="dialect">方言文化</view>
    </view>
  </scroll-view>

  <!-- 语料列表 -->
  <view wx:for="{{corpusItems}}" wx:key="id" class="corpus-item" bindtap="copyItem" data-d="{{item.d}}" data-m="{{item.m}}">
    <view class="corpus-d">{{item.d}}</view>
    <view class="corpus-m">{{item.m}}</view>
    <view class="corpus-meta">
      <text class="corpus-tag">{{item.c}}</text>
      <text class="corpus-tag">{{item.s}}</text>
      <text style="font-size:20rpx;color:#f093fb">{{'★'.repeat(item.f)}}{{'☆'.repeat(5-item.f)}}</text>
    </view>
  </view>

  <!-- 加载更多 -->
  <view style="text-align:center;padding:20rpx" wx:if="{{hasMore}}">
    <button class="btn-ghost" size="mini" bindtap="loadMore">加载更多</button>
  </view>
</view>
