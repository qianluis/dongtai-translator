page{background:#0f0c29;min-height:100vh;color:#e0e0e0;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI','Microsoft YaHei',sans-serif}
.container{padding:16px;padding-bottom:80px}
.card{background:rgba(255,255,255,.06);border-radius:18px;padding:16px;margin-bottom:10px;backdrop-filter:blur(10px);border:1rpx solid rgba(255,255,255,.08)}
.gradient-text{background:linear-gradient(135deg,#667eea,#764ba2,#f093fb);-webkit-background-clip:text;-webkit-text-fill-color:transparent}
.mode-row{display:flex;gap:12rpx;margin-bottom:24rpx}
.mode-btn{flex:1;padding:18rpx;border-radius:20rpx;border:2rpx solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:rgba(255,255,255,.5);font-size:24rpx;font-weight:600;text-align:center}
.mode-btn.active{border-color:#667eea;background:rgba(102,126,234,.15);color:#fff}
.input-area{width:100%;min-height:160rpx;padding:24rpx;border-radius:24rpx;border:2rpx solid rgba(255,255,255,.1);background:rgba(255,255,255,.04);color:#fff;font-size:30rpx}
.result-area{background:rgba(102,126,234,.08);border-radius:24rpx;padding:28rpx;min-height:120rpx;border:1rpx solid rgba(102,126,234,.12)}
.result-text{font-size:34rpx;color:#fff;line-height:1.5;word-break:break-all}
.btn-primary{background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;border:none;border-radius:16rpx;padding:16rpx 32rpx;font-size:28rpx}
.btn-ghost{background:rgba(255,255,255,.06);color:rgba(255,255,255,.6);border:1rpx solid rgba(255,255,255,.12);border-radius:16rpx;padding:16rpx 32rpx;font-size:28rpx}
.voice-btn{width:160rpx;height:160rpx;border-radius:50%;border:none;background:linear-gradient(135deg,#667eea,#764ba2);color:#fff;font-size:60rpx;display:flex;align-items:center;justify-content:center}
.voice-btn.recording{background:linear-gradient(135deg,#e74c3c,#c0392b)}
.dict-section{margin-bottom:20rpx}
.dict-title{font-size:28rpx;font-weight:600;color:#f093fb;margin-bottom:12rpx;padding-left:8rpx}
.dict-items{display:flex;flex-wrap:wrap;gap:8rpx}
.dict-item{background:rgba(255,255,255,.05);border-radius:12rpx;padding:12rpx 20rpx;font-size:24rpx;display:flex;align-items:center;gap:8rpx}
.dict-from{color:rgba(255,255,255,.7)}
.dict-arrow{color:#667eea}
.dict-to{color:#f093fb;font-weight:600}
.corpus-item{background:rgba(255,255,255,.03);border-radius:16rpx;padding:20rpx;margin-bottom:12rpx;border:1rpx solid rgba(255,255,255,.04)}
.corpus-d{font-size:28rpx;color:#f093fb;margin-bottom:6rpx}
.corpus-m{font-size:24rpx;color:rgba(255,255,255,.5)}
.corpus-meta{display:flex;gap:12rpx;margin-top:8rpx;align-items:center}
.corpus-tag{background:rgba(102,126,234,.15);color:#667eea;border-radius:8rpx;padding:4rpx 12rpx;font-size:20rpx}
.search-box{display:flex;gap:12rpx;margin-bottom:20rpx}
.search-input{flex:1;background:rgba(255,255,255,.06);border:1rpx solid rgba(255,255,255,.1);border-radius:16rpx;padding:16rpx 24rpx;color:#fff;font-size:28rpx}
.filter-row{display:flex;gap:8rpx;flex-wrap:wrap;margin-bottom:16rpx}
.filter-pill{background:rgba(255,255,255,.06);border-radius:20rpx;padding:8rpx 20rpx;font-size:22rpx;color:rgba(255,255,255,.5)}
.filter-pill.active{background:rgba(102,126,234,.15);color:#667eea}
